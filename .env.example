# Google Gemini
GEMINI_API_KEY=

# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: use for course writes when RLS restricts anon inserts
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (https://dashboard.stripe.com/test/apikeys) — use test/sandbox keys only
STRIPE_SECRET_KEY=
# Optional locally — success page fulfills plan/credits if user lands after pay.
# Recommended: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Subscription prices from Stripe Product Catalog (monthly recurring, test mode)
# Dashboard → Products → create price → copy price_… ID
STRIPE_PRICE_INDIVIDUAL=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_ENTERPRISE=
